# ═══════════════════════════════════════════
# BrickBot - Variables de entorno
# ═══════════════════════════════════════════

# ── Azure OpenAI ──────────────────────────
# Endpoint base de tu recurso Azure OpenAI
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com

# Auth: API key OR Azure AD token (one of the two)
# Si tu recurso tiene disableLocalAuth=true, usa npm run dev:azure
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_TOKEN=

# Deployment names (deben coincidir con los de Azure AI Foundry)
AZURE_TEXT_MODEL=gpt-5.4
AZURE_IMAGE_MODEL=gpt-image-1.5

# Versión de API de Azure OpenAI
AZURE_API_VERSION=2025-01-01-preview

# ── Rebrickable (base de datos de piezas LEGO) ──
# Consigue tu clave en: https://rebrickable.com/api/
REBRICKABLE_API_KEY=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
