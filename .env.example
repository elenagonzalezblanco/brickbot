# BrickBot - Tu constructor LEGO con IA

# OpenAI API Key (required) - GPT-4o for chat and vision
OPENAI_API_KEY=sk-your-openai-api-key-here

# Rebrickable API Key (required) - For LEGO parts database
# Get yours at: https://rebrickable.com/api/
REBRICKABLE_API_KEY=your-rebrickable-api-key-here

# BrickLink API (optional) - For marketplace pricing
# Get yours at: https://www.bricklink.com/v3/api.page
BRICKLINK_CONSUMER_KEY=your-bricklink-consumer-key
BRICKLINK_CONSUMER_SECRET=your-bricklink-consumer-secret
BRICKLINK_TOKEN=your-bricklink-token
BRICKLINK_TOKEN_SECRET=your-bricklink-token-secret

# App config
NEXT_PUBLIC_APP_URL=http://localhost:3000
