# ═══════════════════════════════════════════
# BrickBot - Variables de entorno
# ═══════════════════════════════════════════

# ── Azure OpenAI / AI Foundry ──────────────
# Endpoint base de tu recurso Azure AI
AZURE_OPENAI_ENDPOINT=https://your-resource.services.ai.azure.com

# API Key de Azure (Keys & Endpoint en Azure Portal)
AZURE_OPENAI_API_KEY=your-azure-api-key-here

# Modelo para texto (ej: gpt-5.4)
AZURE_TEXT_MODEL=gpt-5.4

# Modelo para imágenes (ej: gpt-1.5-image)
AZURE_IMAGE_MODEL=gpt-1.5-image

# Versión de API de Azure OpenAI
AZURE_API_VERSION=2025-01-01-preview

# ── Rebrickable (base de datos de piezas LEGO) ──
# Consigue tu clave en: https://rebrickable.com/api/
REBRICKABLE_API_KEY=your-rebrickable-api-key-here

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
